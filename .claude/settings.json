{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "npm run check && npm run typecheck && npm test -- --run",
            "timeout": 120,
            "statusMessage": "Running quality checks (biome, typecheck, test)..."
          }
        ]
      }
    ]
  }
}
